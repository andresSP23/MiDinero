# Configuración de Base de Datos
DB_PASSWORD=secret

# Configuración de Seguridad (JWT)
# Genera uno seguro con: openssl rand -base64 32
JWT_SECRET=super_secret_key_change_me

# Configuración de Correo (General)
MAIL_FROM=no-reply@midinero.com

# Configuración de Brevo (SMTP)
# Obtén estas credenciales en: https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_USER=tu_usuario_smtp@brevo.com
BREVO_SMTP_PASS=tu_clave_smtp_master

# Configuración de CORS (Frontend URL)
CORS_ORIGIN=http://localhost:4200
